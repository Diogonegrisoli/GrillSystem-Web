<!doctype html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= titulo %> - GrillSystem</title>
    <style>
        * { box-sizing: border-box; }
        body { margin: 0; min-height: 100vh; font-family: Arial, Helvetica, sans-serif; color: #1f2937; background: #f3f6fb; }
        .app-shell { min-height: 100vh; display: grid; grid-template-columns: 260px 1fr; }
        .sidebar { background: #1f3b57; color: #eef6ff; padding: 24px 18px; }
        .brand { font-size: 22px; font-weight: 700; margin-bottom: 30px; }
        .nav { display: grid; gap: 8px; }
        .nav a { color: #dbeafe; text-decoration: none; padding: 12px 14px; border-radius: 6px; display: block; }
        .nav a:hover, .nav a.active { background: #315b80; }
        .main { min-width: 0; padding: 28px; }
        h1 { margin: 0 0 22px; font-size: 26px; color: #172033; }
        form { background: #ffffff; border: 1px solid #d6dee8; border-radius: 8px; padding: 22px; max-width: 820px; }
        .grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 16px; }
        label { display: grid; gap: 7px; color: #526273; font-size: 14px; }
        input, select { min-height: 40px; border: 1px solid #bfccd9; border-radius: 6px; padding: 9px 10px; font-size: 14px; }
        input:disabled { background: #eef3f8; color: #64748b; cursor: not-allowed; }
        .alert { max-width: 820px; margin-bottom: 16px; padding: 12px 14px; border-radius: 6px; border: 1px solid #f0b9b9; background: #fff1f1; color: #9b1c1c; }
        .full { grid-column: 1 / -1; }
        .actions { display: flex; justify-content: flex-end; gap: 10px; margin-top: 20px; }
        .button { min-height: 40px; border: 0; border-radius: 6px; padding: 0 14px; background: #1f5f8f; color: #ffffff; text-decoration: none; display: inline-flex; align-items: center; justify-content: center; cursor: pointer; }
        .button.secondary { background: #60758a; }
        @media (max-width: 760px) { .app-shell { grid-template-columns: 1fr; } .main { padding: 20px; } .grid { grid-template-columns: 1fr; } }
    </style>
</head>
<body>
    <div class="app-shell">
        <aside class="sidebar">
            <div class="brand">GrillSystem</div>
            <nav class="nav" aria-label="Menu principal">
                <a href="/">Início</a>
                <a class="active" href="/clientes/consultar">Clientes</a>
                <a href="#">Produtos</a>
                <a href="#">Pedidos de venda</a>
                <a href="#">Pedidos de compra</a>
                <a href="#">Financeiro</a>
            </nav>
        </aside>
        <main class="main">
            <h1><%= titulo %></h1>
            <% if (erro) { %>
                <div class="alert"><%= erro %></div>
            <% } %>
            <form method="post" action="<%= acao %>">
                <div class="grid">
                    <label>
                        Nome
                        <input name="nome" minlength="3" maxlength="200" required value="<%= cliente ? cliente.nome : '' %>">
                    </label>
                    <label>
                        Tipo
                        <select name="tipo" required>
                            <option value="fisica" <%= cliente && cliente.tipo === 'fisica' ? 'selected' : '' %>>Física</option>
                            <option value="juridica" <%= cliente && cliente.tipo === 'juridica' ? 'selected' : '' %>>Jurídica</option>
                        </select>
                    </label>
                    <label>
                        CPF/CNPJ
                        <input name="cpfCnpj" required value="<%= cliente ? cliente.cpfCnpj : '' %>" <%= cliente && cliente.id ? 'disabled' : '' %>>
                    </label>
                    <label>
                        Telefone
                        <input name="telefone" maxlength="15" required value="<%= cliente ? cliente.telefone : '' %>">
                    </label>
                    <label class="full">
                        Endereço
                        <input name="endereco" minlength="15" maxlength="300" required value="<%= cliente ? cliente.endereco : '' %>">
                    </label>
                </div>
                <div class="actions">
                    <a class="button secondary" href="/clientes/consultar">Cancelar</a>
                    <button class="button" type="submit">Salvar</button>
                </div>
            </form>
        </main>
    </div>
</body>
</html>

<!doctype html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Entrar - GrillSystem</title>
    <style>
        * { box-sizing: border-box; }
        body { margin: 0; min-height: 100vh; display: grid; place-items: center; padding: 24px; font-family: Arial, Helvetica, sans-serif; color: #1f2937; background: #eef3f8; }
        .login { width: min(420px, 100%); }
        .brand { margin-bottom: 24px; color: #1f3b57; font-size: 28px; font-weight: 700; text-align: center; }
        .panel { padding: 28px; border: 1px solid #d6dee8; border-radius: 8px; background: #ffffff; box-shadow: 0 12px 30px rgba(31, 59, 87, .08); }
        h1 { margin: 0 0 8px; color: #172033; font-size: 24px; }
        .subtitle { margin: 0 0 22px; color: #64748b; font-size: 14px; }
        .field { display: grid; gap: 7px; margin-bottom: 16px; color: #526273; font-size: 14px; }
        input { width: 100%; min-height: 44px; border: 1px solid #bfccd9; border-radius: 6px; padding: 10px 12px; font-size: 15px; }
        input:focus { border-color: #1f5f8f; outline: 2px solid #bfdbfe; outline-offset: 1px; }
        .alert { margin-bottom: 16px; padding: 12px 14px; border: 1px solid #f0b9b9; border-radius: 6px; background: #fff1f1; color: #9b1c1c; font-size: 14px; }
        .button { width: 100%; min-height: 44px; margin-top: 4px; border: 0; border-radius: 6px; background: #1f5f8f; color: #ffffff; font-size: 15px; font-weight: 700; cursor: pointer; }
        .button:hover { background: #184d75; }
    </style>
</head>
<body>
    <main class="login">
        <div class="brand">GrillSystem</div>
        <section class="panel">
            <h1>Entrar no sistema</h1>
            <p class="subtitle">Informe suas credenciais para continuar.</p>
            <% if (erro) { %><div class="alert" role="alert"><%= erro %></div><% } %>
            <form method="post" action="/login">
                <label class="field">
                    <span>E-mail</span>
                    <input type="email" name="email" value="<%= email %>" autocomplete="username" required autofocus>
                </label>
                <label class="field">
                    <span>Senha</span>
                    <input type="password" name="senha" minlength="6" autocomplete="current-password" required>
                </label>
                <button class="button" type="submit">Entrar</button>
            </form>
        </section>
    </main>
</body>
</html>
